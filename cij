#!/usr/bin/env lua5.3

local os = require("os")
local io = require("io")

-- ==========================================================
-- ROBLOX INJECTOR v10.1 (LUA EDITION - OVERWRITE + VALIDATOR)
-- ==========================================================

local TERMUX_SQLITE = "/data/data/com.termux/files/usr/bin/sqlite3"
local TMP_SQLITE = "/data/local/tmp/sqlite3_exec"
local TEMP_DB_DIR = "/data/local/tmp/rbx_temp_cookies"
local SQLITE_BIN = ""

-- Fungsi Utilitas Eksekusi Command
local function exec(cmd)
    local f = io.popen(cmd)
    if not f then return "" end
    local result = f:read("*a")
    f:close()
    return (result:gsub("^%s*(.-)%s*$", "%1")) -- trim whitespace
end

-- Cek Akses Root
local function check_root()
    local uid = exec("id -u")
    if uid ~= "0" then
        print("❌ Script ini MEMBUTUHKAN akses Root!")
        print("   Jalankan dengan: tsu -c 'lua5.3 nama_script.lua' atau sudo lua5.3 nama_script.lua")
        os.exit(1)
    end
end

-- Persiapan Environment
local function prepare_env()
    if exec("command -v curl") == "" then
        print("❌ Curl tidak ditemukan. Install dulu: pkg install curl")
        os.exit(1)
    end

    os.execute("rm -f " .. TMP_SQLITE)
    
    -- Memindahkan sqlite3 ke folder tmp agar tidak bentrok library saat run via Root
    if exec("ls " .. TERMUX_SQLITE .. " 2>/dev/null") ~= "" then
        os.execute("cp " .. TERMUX_SQLITE .. " " .. TMP_SQLITE)
        os.execute("chmod 755 " .. TMP_SQLITE)
        SQLITE_BIN = TMP_SQLITE
    else
        SQLITE_BIN = exec("which sqlite3")
    end

    if SQLITE_BIN == "" or exec("ls " .. SQLITE_BIN .. " 2>/dev/null") == "" then
        print("❌ sqlite3 tidak ditemukan. Wajib install: pkg install sqlite")
        os.exit(1)
    end

    os.execute("rm -rf " .. TEMP_DB_DIR)
    os.execute("mkdir -p " .. TEMP_DB_DIR)
    os.execute("chmod 777 " .. TEMP_DB_DIR)
end

-- --- FUNGSI 1: CEK APAKAH APK SUDAH LOGIN ---
local function check_existing_cookie(pkg)
    local db_path = "/data/data/" .. pkg .. "/app_webview/Default/Cookies"
    
    if exec("ls " .. db_path .. " 2>/dev/null") == "" then
        return false
    end

    local cookie_value = exec(SQLITE_BIN .. " " .. db_path .. " \"SELECT value FROM cookies WHERE name='.ROBLOSECURITY' LIMIT 1;\" 2>/dev/null")
    
    if cookie_value and cookie_value ~= "" then
        return true -- Ada isinya (Sudah login)
    else
        return false -- Kosong
    end
end

-- --- FUNGSI 2: CEK VALIDITAS COOKIE VIA INTERNET ---
local function validate_cookie_online(cookie_val)
    io.write("   ⏳ Mengecek validitas... ")
    io.flush()
    
    -- Hit API Roblox
    local cmd = string.format("curl -s -o /dev/null -w \"%%{http_code}\" --max-time 10 -H \"Cookie: .ROBLOSECURITY=%s\" \"https://users.roblox.com/v1/users/authenticated\"", cookie_val)
    local response = exec(cmd)

    if response == "200" then
        print("✅ VALID (Live)")
        return true
    else
        print("❌ MATI/INVALID (" .. response .. ")")
        return false
    end
end

