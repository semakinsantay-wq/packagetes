    -- Tulis query SQL ke file sementara untuk menghindari error escaping karakter
    local sql_script_path = TEMP_DB_DIR .. "/query_" .. index .. ".sql"
    local sql_file = io.open(sql_script_path, "w")
    
    sql_file:write("CREATE TABLE cookies(creation_utc INTEGER NOT NULL, top_frame_site_key TEXT NOT NULL, host_key TEXT NOT NULL, name TEXT NOT NULL, value TEXT NOT NULL, encrypted_value BLOB DEFAULT '', path TEXT NOT NULL, expires_utc INTEGER NOT NULL, is_secure INTEGER NOT NULL, is_httponly INTEGER NOT NULL, last_access_utc INTEGER NOT NULL, has_expires INTEGER NOT NULL DEFAULT 1, is_persistent INTEGER NOT NULL DEFAULT 1, priority INTEGER NOT NULL DEFAULT 1, samesite INTEGER NOT NULL DEFAULT -1, source_scheme INTEGER NOT NULL DEFAULT 0, source_port INTEGER NOT NULL DEFAULT -1, is_same_party INTEGER NOT NULL DEFAULT 0, UNIQUE (top_frame_site_key, host_key, name, path));\n")
    sql_file:write("CREATE TABLE meta(key LONGVARCHAR NOT NULL UNIQUE PRIMARY KEY, value LONGVARCHAR);\n")
    sql_file:write("INSERT INTO meta(key, value) VALUES('version','15');\n")
    sql_file:write("INSERT INTO meta(key, value) VALUES('last_compatible_version','15');\n")
    
